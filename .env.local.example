# Copy this file to .env.local and fill in your keys

# MiniMax API (required for Study Buddy chat, quiz generation, and content curation)
MINIMAX_API_KEY=your_key_here

# Cantonese.ai API (required for Cantonese quiz audio)
CANTONESE_AI_API_KEY=your_key_here

# HeyGen API (required for avatar video generation)
HEYGEN_API_KEY=your_key_here
# Get avatar_id from: GET https://api.heygen.com/v2/avatars (use a stock avatar)
# Get voice_id from:  GET https://api.heygen.com/v2/voices
HEYGEN_AVATAR_ID=Daisy-inskirt-20220818
HEYGEN_VOICE_ID=2d5b0e6cf36f460aa7fc47e3eee4ba54

# Supabase (required for persistent progress, spaced repetition)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
