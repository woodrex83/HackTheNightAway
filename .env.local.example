# Copy this file to .env.local and fill in your keys

# Minimax API (required for AI video generation + quiz generation)
MINIMAX_API_KEY=your_key_here

# Cantonese.ai API (required for Cantonese audio narration)
CANTONESE_AI_API_KEY=your_key_here

# Supabase (required for persistent progress, spaced repetition)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
